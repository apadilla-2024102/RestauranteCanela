# Variables de entorno para Restaurante Canela Frontend
# Copia este archivo como .env y configura los valores

# URL del servicio de autenticación
# Ajusta esto según el puerto donde se ejecute auth-service
# Si arranca con HTTPS usa https://localhost:7111/api/v1
VITE_AUTH_API_URL=http://localhost:5296/api/v1

# URL del servicio de restaurantes
VITE_API_URL=http://localhost:5000/api/v1